<!DOCTYPE html>
<html lang="zh">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VoiceHub 点歌系统 | 咸林智维</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            height: 100vh;
            overflow: hidden;
            background-color: #0a1929;
        }
        .voicehub-container {
            width: 100%;
            height: 100vh;
            border: none;
        }
        .loading {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            color: #b8d0e0;
            font-family: system-ui, sans-serif;
            z-index: 999;
            background: rgba(10, 25, 41, 0.9);
            padding: 1rem 2rem;
            border-radius: 8px;
            font-size: 1rem;
        }
    </style>
</head>
<body>
    <div class="loading" id="loading">🎵 加载 VoiceHub ...</div>
    <iframe 
        src="https://245959623.xyz" 
        class="voicehub-container"
        onload="document.getElementById('loading').style.display = 'none'"
    ></iframe>
</body>
</html>
